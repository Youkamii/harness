#!/usr/bin/env bash
# 전역 harness 명령. install.sh 가 ~/.local/bin/harness 로 설치하며,
# 그때 __HARNESS_DIR__ 이 실제 저장소 경로로 치환된다.
set -euo pipefail
HARNESS_DIR="__HARNESS_DIR__"

cmd="${1:-help}"
[ $# -gt 0 ] && shift

case "$cmd" in
  update)  # 저장소 최신화 + 재설치 (다른 PC에서 수정사항 받을 때)
    git -C "$HARNESS_DIR" pull --ff-only
    "$HARNESS_DIR/install.sh"
    ;;
  run)     # 장기 실행: harness run "목표" [--cwd DIR] [--max-sessions N]
    node "$HARNESS_DIR/orchestrator/run.mjs" "$@"
    ;;
  eval)    # 하네스 성능 측정: harness eval [태스크이름]
    node "$HARNESS_DIR/evals/run.mjs" "$@"
    ;;
  test)    # 훅 회귀 테스트 전부 실행
    node "$HARNESS_DIR/.claude/hooks/guard.test.mjs"
    node "$HARNESS_DIR/.claude/hooks/secrets-guard.test.mjs"
    ;;
  edit)    # 하네스 소스를 Claude Code로 열어 수정
    cd "$HARNESS_DIR" && exec claude
    ;;
  dir)     # 저장소 경로 출력
    echo "$HARNESS_DIR"
    ;;
  help|*)
    cat <<'EOF'
harness — 개인 하네스 명령

  harness update   저장소 pull + 재설치 (수정사항 반영)
  harness run "목표" [--cwd 대상폴더]   장기 실행 에이전트
  harness eval [태스크]                 하네스 성능 측정
  harness test                          guard 훅 테스트
  harness edit                          하네스 소스를 Claude Code로 열기
  harness dir                           저장소 경로

평소 사용은 그냥 아무 폴더에서 `claude` 실행 — 하네스는 자동 적용됨.
EOF
    ;;
esac
