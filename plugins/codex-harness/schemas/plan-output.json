{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["summary", "assumptions", "nonGoals", "tasks"],
  "properties": {
    "summary": { "type": "string", "maxLength": 2000 },
    "assumptions": {
      "type": "array",
      "maxItems": 20,
      "items": { "type": "string", "maxLength": 500 }
    },
    "nonGoals": {
      "type": "array",
      "maxItems": 20,
      "items": { "type": "string", "maxLength": 500 }
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "dependencies",
          "acceptanceCriteria",
          "ownedPaths",
          "checks",
          "risk"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,63}$" },
          "title": { "type": "string", "minLength": 1, "maxLength": 160 },
          "dependencies": {
            "type": "array",
            "uniqueItems": true,
            "items": { "type": "string" }
          },
          "acceptanceCriteria": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1, "maxLength": 500 }
          },
          "ownedPaths": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1, "maxLength": 300 }
          },
          "checks": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["argv"],
              "properties": {
                "argv": {
                  "type": "array",
                  "minItems": 1,
                  "items": { "type": "string", "maxLength": 500 }
                },
                "cwd": { "type": "string", "maxLength": 300 },
                "timeoutMs": { "type": "integer", "minimum": 1000, "maximum": 1800000 },
                "required": { "type": "boolean" }
              }
            }
          },
          "risk": { "enum": ["low", "medium", "high"] }
        }
      }
    }
  }
}
