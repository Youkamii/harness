{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["verdict", "commands", "criteria", "findings", "residualRisks"],
  "properties": {
    "verdict": { "enum": ["approved", "blocked"] },
    "commands": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["argv", "exitCode"],
        "properties": {
          "argv": { "type": "array", "items": { "type": "string", "maxLength": 500 } },
          "exitCode": { "type": "integer" }
        }
      }
    },
    "criteria": {
      "type": "array",
      "maxItems": 200,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status", "evidence"],
        "properties": {
          "id": { "type": "string", "maxLength": 200 },
          "status": { "enum": ["pass", "fail", "unknown"] },
          "evidence": { "type": "string", "maxLength": 2000 }
        }
      }
    },
    "findings": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "file", "line", "evidence", "confidence", "suggestedTest"],
        "properties": {
          "severity": { "enum": ["critical", "high", "medium", "low"] },
          "file": { "type": "string", "maxLength": 500 },
          "line": { "type": "integer", "minimum": 1 },
          "evidence": { "type": "string", "maxLength": 3000 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "suggestedTest": { "type": "string", "maxLength": 2000 }
        }
      }
    },
    "residualRisks": {
      "type": "array",
      "maxItems": 50,
      "items": { "type": "string", "maxLength": 1000 }
    }
  }
}

